{
  "$schema": "https://raw.githubusercontent.com/bee-logical/claude-sdlc/main/docs/sdlc.config.schema.json",
  "$comment": "POLYREPO EXAMPLE. Copy the workspace+repos shape into your sdlc.config.json when the workspace holds several git repos. In poly mode the top-level git/stack/ux blocks are ignored — each repo carries its own. This file lives at the WORKSPACE ROOT (the control plane); the product repos are subfolders under workspace.root.",
  "project": {
    "key": "PROJ",
    "name": "Example polyrepo product"
  },
  "workItems": {
    "source": "markdown",
    "jira": { "site": "", "project": "", "statusMap": {} },
    "ado": { "org": "", "project": "", "statusMap": {} }
  },
  "workspace": {
    "layout": "poly",
    "root": "."
  },
  "repos": [
    {
      "name": "backend",
      "path": "backend",
      "role": "REST API service — NestJS + Postgres",
      "host": "github",
      "remote": "origin",
      "defaultBranch": "main",
      "branchPattern": "{type}/{id}-{slug}",
      "stack": { "frontend": null, "backend": "nestjs", "databases": ["postgres"] },
      "labels": ["backend", "api", "server"],
      "default": true
    },
    {
      "name": "frontend",
      "path": "frontend",
      "role": "Customer web app — Next.js",
      "host": "github",
      "remote": "origin",
      "defaultBranch": "main",
      "branchPattern": "{type}/{id}-{slug}",
      "stack": { "frontend": "nextjs", "backend": null, "databases": [] },
      "labels": ["frontend", "web", "ui"],
      "ux": {
        "enabled": true,
        "target": "desktop-web",
        "renderBaseUrl": "http://localhost:3000",
        "uiPaths": ["app/**", "src/app/**", "components/**", "src/components/**", "**/*.tsx", "**/*.css"]
      }
    },
    {
      "name": "website",
      "path": "website",
      "role": "Marketing site — Next.js static",
      "host": "azure-repos",
      "remote": "origin",
      "defaultBranch": "main",
      "branchPattern": "{type}/{id}-{slug}",
      "stack": { "frontend": "nextjs", "backend": null, "databases": [] },
      "labels": ["website", "marketing", "landing"],
      "ux": {
        "enabled": true,
        "target": "desktop-web",
        "renderBaseUrl": "http://localhost:3001",
        "uiPaths": ["app/**", "src/**", "**/*.tsx", "**/*.css"]
      }
    },
    {
      "name": "mobile",
      "path": "mobile",
      "role": "React Native / Expo app",
      "host": "github",
      "remote": "origin",
      "defaultBranch": "main",
      "branchPattern": "{type}/{id}-{slug}",
      "stack": { "frontend": "react-native", "backend": null, "databases": [] },
      "labels": ["mobile", "app", "ios", "android"]
    }
  ],
  "pipeline": {
    "autonomy": "high",
    "maxFixCycles": 3,
    "architectThreshold": "M",
    "securityReviewPaths": ["**/auth/**", "**/*.env*", "package.json", "**/middleware*"],
    "gates": {
      "ambiguousRequirements": "assume-and-log"
    },
    "verification": {
      "mode": "auto",
      "reviewer": "on-demand",
      "qa": "on-demand",
      "security": "per-epic",
      "securityConfirm": true
    }
  },
  "marketplace": {
    "repo": "bee-logical/claude-sdlc",
    "promotionBranchPrefix": "promote/"
  }
}
