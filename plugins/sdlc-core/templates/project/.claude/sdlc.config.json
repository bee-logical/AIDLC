{
  "$schema": "https://raw.githubusercontent.com/bee-logical/claude-sdlc/main/docs/sdlc.config.schema.json",
  "project": {
    "key": "{{PROJECT_KEY}}",
    "name": "{{PROJECT_NAME}}"
  },
  "workItems": {
    "source": "markdown",
    "jira": { "site": "", "project": "", "statusMap": {} },
    "ado": { "org": "", "project": "", "statusMap": {} }
  },
  "git": {
    "host": "github",
    "defaultBranch": "main",
    "remote": "origin",
    "branchPattern": "{type}/{id}-{slug}"
  },
  "stack": {
    "frontend": "nextjs",
    "backend": "nestjs",
    "databases": ["postgres", "mongodb"]
  },
  "pipeline": {
    "autonomy": "high",
    "maxFixCycles": 3,
    "architectThreshold": "M",
    "securityReviewPaths": ["**/auth/**", "**/*.env*", "package.json", "**/middleware*"],
    "gates": {
      "ambiguousRequirements": "assume-and-log"
    },
    "verification": {
      "mode": "auto",
      "scope": "per-item",
      "reviewer": true,
      "qa": true,
      "security": "risk-based"
    }
  },
  "ux": {
    "enabled": true,
    "target": "desktop-web",
    "juryThreshold": 9,
    "maxJuryRounds": 3,
    "juryPanelSize": 1,
    "renderBaseUrl": "http://localhost:3000",
    "uiPaths": ["app/**", "src/app/**", "components/**", "src/components/**", "**/*.tsx", "**/*.css"],
    "brand": {
      "referenceDir": "design/brand",
      "logo": "",
      "palette": [],
      "fonts": { "display": "", "body": "", "mono": "" },
      "guidelines": ""
    }
  },
  "marketplace": {
    "repo": "bee-logical/claude-sdlc",
    "promotionBranchPrefix": "promote/"
  }
}
